[bootstrap]
main_collection = /main/main.collectionc

[script]
shared_state = 1

[display]
width = 288
height = 208
high_dpi = 0
fullscreen = 0

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01
use_fixed_timestep = 1

[html5]
scale_mode = stretch

[project]
title = Rocket Cherry

[graphics]
default_texture_min_filter = nearest
default_texture_mag_filter = nearest

[sprite]
subpixels = 0

